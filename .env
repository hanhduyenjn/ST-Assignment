# ──────────────────────────────────────────────────────────────────────────────
# Network Health Platform — Runtime Credentials
# NOTE: In a real project this file would be in .gitignore.
# It is committed here so the ST team can run `docker compose up` as-is.
# ──────────────────────────────────────────────────────────────────────────────

# MinIO (on-prem S3 object store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000

# Iceberg REST Catalog
ICEBERG_REST_CATALOG_URL=http://iceberg-rest:8181

# ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=network_health
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Spark
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Application
PROMETHEUS_PORT=8000

# Airflow
AIRFLOW_FERNET_KEY=BsCTo_gJVaRFqLWcwtyVuUUY1vVLavHffYUlkNgUa5k=
