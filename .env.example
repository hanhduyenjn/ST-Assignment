# ──────────────────────────────────────────────────────────────────────────────
# Network Health Platform — Environment Variables
# Copy this file to .env and fill in your values.
# .env should be in .gitignore for real deployments
# ──────────────────────────────────────────────────────────────────────────────

# MinIO (on-prem S3 object store)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://minio:9000

# Iceberg REST Catalog
ICEBERG_REST_CATALOG_URL=http://iceberg-rest:8181

# ClickHouse
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=network_health
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Grafana
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# Spark
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# Application
PROMETHEUS_PORT=8000
